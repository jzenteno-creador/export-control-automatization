# Dashboard SSB — variables de entorno locales
# Copiar este archivo a .env.local y completar los valores.
# .env.local está gitignoreado — NO se sube al repo.

# ─── Supabase ──────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PROJECT_REF=<project-ref>

# Keys públicas (OK exponer en cliente)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_ANON_KEY=eyJ...

# Key privada — usar SOLO desde server / Edge Function.
# Copiar desde Dashboard → Settings → API → service_role key.
# Para el Walking Skeleton NO es estrictamente necesaria:
# la Edge Function la recibe inyectada automáticamente por Supabase en runtime.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Webhook receptor del 304 ──────────────────────────────────────
# Shared secret para el header X-Webhook-Secret.
# Generar un valor nuevo con: openssl rand -hex 24
WEBHOOK_SECRET=
